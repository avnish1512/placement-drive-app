{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Expo Web Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "start-web"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Expo.*web.*",
          "endsPattern": "^.*Local:.*http"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
